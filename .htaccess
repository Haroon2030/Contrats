<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /mordun/

    # الملفات الثابتة
    RewriteRule ^public/ - [L]
    RewriteRule ^uploads/ public/uploads/ [L]
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]

    # الصفحة الرئيسية
    RewriteRule ^$ index.php?page=login [L,QSA]

    # توجيه الشاشات إلى Front Controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([A-Za-z0-9_]+)\.php$ index.php?page=$1 [L,QSA]
</IfModule>

# منع عرض قائمة المجلدات
Options -Indexes
