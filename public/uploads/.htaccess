# منع استعراض المجلد وتنفيذ السكربتات داخل uploads
Options -Indexes

<IfModule mod_authz_core.c>
    <FilesMatch "\.(?i)(php|phtml|php[0-9]|phar|cgi|pl|asp|aspx|jsp)$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
    <FilesMatch "\.(?i)(php|phtml|php[0-9]|phar|cgi|pl|asp|aspx|jsp)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>
